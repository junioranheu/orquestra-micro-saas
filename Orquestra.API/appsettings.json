{
  "SystemSettings": {
    "ConnectionStringName": "DBConnection"
  },

  "JwtSettings": {
    "TokenExpiryMinutes": 30,
    "RefreshTokenExpiryMinutes": 20160,
    "Issuer": "Orquestra.API",
    "Audience": "Orquestra.API"
  },

  "CORSSettings": {
    "Cors": "_CorsPolicy"
  },

  "Logging": {
    "LogLevel": {
      // Nível global de logs para toda a aplicação;
      "Default": "Information",

      // Logs do framework Microsoft (ASP.NET Core, EF Core, etc.);
      // Só vai mostrar Warning ou Error, escondendo logs de informação normais;
      "Microsoft": "Warning",

      // Logs específicos de comandos SQL executados pelo EF Core;
      // Queries rápidas não aparecem, só warnings e erros do EF Core;
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  "Urls": {
    "Development": {
      "Backend": "http://localhost:5035/api",
      "Frontend": "http://localhost:3000"
    },
    "Production": {
      "Backend": "https://orquestra-api-linux.azurewebsites.net/api",
      "Frontend": "https://orquestra-web.vercel.app",
      "Frontend_2": "https://orquestra-web.azurewebsites.net"
    }
  }
}